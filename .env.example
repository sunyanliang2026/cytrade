# CyTrade2 local environment example
# Copy values into your shell / process manager; do not commit real secrets.

QMT_PATH=D:\path\to\userdata_mini
ACCOUNT_ID=your_account_id
ACCOUNT_PASSWORD=your_account_password

SQLITE_DB_PATH=./data/db/cytrade2.db
STATE_SAVE_DIR=./saved_states
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_SUMMARY_MODE=false

WEB_HOST=0.0.0.0
WEB_PORT=8080

SUBSCRIPTION_PERIOD=tick
DATA_LATENCY_THRESHOLD_SEC=10
STRATEGY_PROCESS_THRESHOLD_MS=200
COST_METHOD=moving_average

WATCHDOG_INTERVAL_SEC=30
POSITION_REPORT_TIMES=09:35,11:35,15:05
CPU_ALERT_THRESHOLD=80
MEM_ALERT_THRESHOLD=80

DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

ENABLE_REMOTE_DB=false
REMOTE_DB_CONFIG={"host":"","port":5432,"dbname":"","user":"","password":""}

RECONNECT_BASE_SEC=1
RECONNECT_MAX_INTERVAL_SEC=60
RECONNECT_MAX_RETRIES=0
